generator client {
	provider = "prisma-client"
	output   = "../app/generated/prisma"
}

datasource db {
	provider = "mysql"
	url      = env("DATABASE_URL")
}

model User {
	id					Int			@id @default(autoincrement())

	firstname			String
	lastname			String
	phoneNumber			String?
	email				String		@unique
	password			String

//	badge				Badge[]
//	orgs				Organization[]

	createdAt 			DateTime 	@default(now())
	updatedAt 			DateTime
}



model Organization {
	id				Int			@id @default(autoincrement())

//	admin			User		@relation(fields: [adminId], references: [id])
//	adminId			Int

	apiURL			String
}


model Badge {
	id			String	@id @default(uuid())

//	user		User	@relation(fields: [userId], references: [id])
//	userId		String

}

model BadgeHistory {
	id					Int			@id @default(autoincrement())
}



