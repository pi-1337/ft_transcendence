// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

datasource db {
	provider = "mysql"
	url      = env("DATABASE_URL")
}

generator client {
	provider = "prisma-client-js"
}

enum ACTIVE {
	TRUE
	FALSE
}

model User {
	id					Int				@id @default(autoincrement())

	firstname			String
	lastname			String
	phoneNumber			String
	email				String			@unique
	password			String

	badge				Badge[]
	orgs				Organization[]	@relation("membership")
	owned_orgs			Organization[]	@relation("administration")

	// not used by dev
	membership			UsersOnOrganizations[]

	createdAt 			DateTime 		@default(now())
	updatedAt 			DateTime?
}



model Organization {
	id				Int			@id @default(autoincrement())

	name			String
	type			String
	service			String
	badgeTimes		Int
	active			ACTIVE		@default(FALSE)

	users			User[]		@relation("membership")
	admin			User		@relation("administration", fields: [adminId], references: [id])
	adminId			Int

	membership		UsersOnOrganizations[]

	badges			Badge[] // badges of users in the org

	callBackURL		String? // post req sending the data using a jwt

	createdAt 		DateTime 	@default(now())
	updatedAt 		DateTime?
}


model Badge {
	number		BigInt			@unique

	user		User			@relation(fields: [userId], references: [id])
	userId		Int

	org			Organization	@relation(fields: [orgId], references: [id])
	orgId		Int

	txs			BadgeTX[]

	createdAt	DateTime		@default(now())
	@@id([userId, orgId])
}

model BadgeTX {
	id				Int			@id @default(autoincrement())

	badge			Badge		@relation(fields: [badgeNumber], references: [number])
	badgeNumber		BigInt

	createdAt		DateTime	@default(now())
}


// many to many relations
// users and orgs
model UsersOnOrganizations {
	user	User?			@relation(fields: [userId], references: [id])
	userId	Int
	org		Organization	@relation(fields: [orgId], references: [id])
	orgId	Int
	@@id([userId, orgId]) // pair (id, id) is uniq in IR^2
}

