// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

datasource db {
	provider = "mysql"
	url      = env("DATABASE_URL")
}

generator client {
	provider = "prisma-client-js"
}

enum Active {
	TRUE
	FALSE
}

enum Role {
	ADMIN
	USER
}

model User {
	id					Int				@id @default(autoincrement())

	firstname			String
	lastname			String
	phoneNumber			String
	email				String			@unique
	password			String
	role				Role			@default(USER)

	badge				Badge[]
	orgs				Organization[]	@relation("membership")
	owned_orgs			Organization[]	@relation("administration")
	notifications		Notification[]

	// not used by dev
	membership			UsersOnOrganizations[]

	createdAt 			DateTime 		@default(now())
	updatedAt 			DateTime?
}



model Organization {
	id				Int			@id @default(autoincrement())

	name			String
	type			String
	service			String
	badgeTimes		Int
	active			Active		@default(FALSE)

	users			User[]		@relation("membership")
	admin			User		@relation("administration", fields: [adminId], references: [id])
	adminId			Int

	membership		UsersOnOrganizations[]

	badges			Badge[] // badges of users in the org

	callBackURL		String? // post req sending the data using a jwt

	createdAt 		DateTime 	@default(now())
	updatedAt 		DateTime?
}


model Badge {
	number		String			@unique

	user		User			@relation(fields: [userId], references: [id])
	userId		Int

	org			Organization	@relation(fields: [orgId], references: [id])
	orgId		Int

	txs			BadgeTX[]

	createdAt	DateTime		@default(now())
	@@id([userId, orgId])
}

model BadgeTX {
	id				Int			@id @default(autoincrement())

	badge			Badge		@relation(fields: [badgeNumber], references: [number])
	badgeNumber		String

	createdAt		DateTime	@default(now())
}


model Notification {
	id				Int			@id @default(autoincrement())

	user			User		@relation(fields: [userId], references: [id], onDelete: Cascade)
	userId			Int

	type			String		// "badge_awarded", "user_added", "badge_recorded"
	title			String
	message			String
	read			Boolean		@default(false)

	relatedOrgId	Int?		// reference to organization
	relatedBadgeId	String?		// reference to badge number
	relatedUserId	Int?		// reference to user who triggered notification

	createdAt		DateTime	@default(now())
	updatedAt		DateTime?
}

// many to many relations
// users and orgs
model UsersOnOrganizations {
	user	User?			@relation(fields: [userId], references: [id])
	userId	Int
	org		Organization	@relation(fields: [orgId], references: [id])
	orgId	Int
	@@id([userId, orgId]) // pair (id, id) is uniq in IR^2
}

