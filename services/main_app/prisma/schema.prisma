TOTAL RECORD// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

datasource db {
	provider = "mysql"
	url      = env("DATABASE_URL")
}

generator client {
	provider = "prisma-client-js"
}

enum Active {
	TRUE
	FALSE
}

enum Role {
	ADMIN
	USER
}

model User {
	id					Int				@id @default(autoincrement())

	firstname			String
	lastname			String
	avatar				String?
	phoneNumber			String?
	email				String			@unique
	login				String?			@unique
	password			String?
	role				Role			@default(USER)
	twoFactorEnabled	Boolean			@default(false)
	twoFactorEmail		String?

	badge				Badge?

	unreadNotifications	Notification[]	@relation("unread")
	readNotifications	Notification[]	@relation("read")
	orgs				Organization[]	@relation("membership")
	owned_orgs			Organization[]	@relation("administration")
	announcements		Announcement[]	@relation("createdBy")

	// not used by dev
	membership			UsersOnOrganizations[]
	read				UsersOnNotificationsRead[]
	unread				UsersOnNotifications[]
	twoFactorChallenges	TwoFactorChallenge[]

	createdAt 			DateTime 		@default(now())
	updatedAt 			DateTime?
}

model Notification {
	id				Int			@id @default(autoincrement())

	unreadUsers		User[]		@relation("unread")
	readUsers		User[]		@relation("read")

	message			String

	read			UsersOnNotificationsRead[]
	unread			UsersOnNotifications[]

	createdAt 		DateTime 	@default(now())
}

model Organization {
	id				Int			@id @default(autoincrement())

	name			String
	type			String
	service			String
	badgeTimes		Int
	active			Active		@default(FALSE)

	users			User[]		@relation("membership")
	admins			User[]		@relation("administration")

	membership		UsersOnOrganizations[]

	meals			Meal[]
	announcements	Announcement[]
	callBackURL		String? // post req sending the data using a jwt

	createdAt 		DateTime 	@default(now())
	updatedAt 		DateTime?

	readers    RfidReaders[]
}

model Meal {
	id				Int			@id @default(autoincrement())

	name			String
	startTime		DateTime	@db.Time(0)
	endTime			DateTime	@db.Time(0)

	organization		Organization	@relation(fields: [organizationId], references: [id])
	organizationId		Int

	createdAt		DateTime	@default(now())
	updatedAt		DateTime?

	badgeScans    BadgeScan[]

	@@index([organizationId])
}


model Badge {
	number String @id
	user   User   @relation(fields: [userId], references: [id])
	userId Int    @unique
	createdAt DateTime @default(now())

	badgeScan BadgeScan[]
}

model Announcement {
	id				Int				@id @default(autoincrement())

	title			String
	message			String

	organization		Organization	@relation(fields: [organizationId], references: [id], onDelete: Cascade)
	organizationId		Int

	createdBy			User			@relation("createdBy", fields: [userId], references: [id])
	userId				Int

	createdAt			DateTime		@default(now())
	updatedAt			DateTime?

	@@index([organizationId])
	@@index([userId])
}

enum TwoFactorPurpose {
	LOGIN
	ENABLE
	DISABLE
}

model TwoFactorChallenge {
	id				Int					@id @default(autoincrement())
	user				User				@relation(fields: [userId], references: [id], onDelete: Cascade)
	userId				Int
	purpose			TwoFactorPurpose
	codeHash			String
	expiresAt			DateTime
	consumedAt			DateTime?
	attempts			Int					@default(0)
	resendCount			Int					@default(0)
	lastSentAt			DateTime			@default(now())
	createdAt			DateTime			@default(now())

	@@index([userId, purpose])
	@@index([expiresAt])
}



// many to many relations
// users and orgs
model UsersOnOrganizations {
	user	User?			@relation(fields: [userId], references: [id])
	userId	Int
	org		Organization	@relation(fields: [orgId], references: [id])
	orgId	Int
	@@id([userId, orgId]) // pair (id, id) is uniq in IR^2
}

model UsersOnNotifications {
	user	User?			@relation(fields: [userId], references: [id])
	userId	Int
	notif	Notification	@relation(fields: [notifId], references: [id])
	notifId	Int
	@@id([userId, notifId])
}

model UsersOnNotificationsRead {
	user	User?			@relation(fields: [userId], references: [id])
	userId	Int
	notif	Notification	@relation(fields: [notifId], references: [id])
	notifId	Int
	@@id([userId, notifId])
}

model RfidReaders {
	id Int @id @default(autoincrement())
	location String
	organization    Organization @relation(fields: [organizationId], references: [id])
    organizationId  Int

	badgeScan BadgeScan[]
}

enum RequestStatus {
  PENDING
  ACCEPTED
  REJECTED
}

model BadgeScan {
  id            Int      @id @default(autoincrement())

  badgeId       String
  badge Badge @relation(fields: [badgeId], references: [number])

  rfidReaderID       Int
  rfidReader RfidReaders @relation(fields: [rfidReaderID], references: [id])

  mealId        Int
  meal          Meal     @relation(fields: [mealId], references: [id])

  status        RequestStatus @default(PENDING)
  createdAt     DateTime @default(now())
}
