server {
	listen 80;

	return 301 https://$host$request_uri;
}

server {
	listen 3000 ssl;

	ssl_certificate	 /etc/nginx/ssl/certificate.cert;
	ssl_certificate_key /etc/nginx/ssl/private.key;

	proxypass http://main_app:3000
}

server {
	listen 3001 ssl;

	ssl_certificate	 /etc/nginx/ssl/certificate.cert;
	ssl_certificate_key /etc/nginx/ssl/private.key;

	proxypass http://public_api:3001
}

server {
	listen 3002 ssl;

	ssl_certificate	 /etc/nginx/ssl/certificate.cert;
	ssl_certificate_key /etc/nginx/ssl/private.key;

	proxypass http://avatar_server:80
}
